# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Application Environment
NODE_ENV=production
APP_NAME=job-app
APP_VERSION=1.0.0
LOG_LEVEL=info

# Server Configuration
PORT=5000
API_BASE_URL=http://localhost:5000/api

# Database Configuration
DATABASE_URL=mysql://app_user:apppassword@mysql:3306/job_app_db
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=job_app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=apppassword
MYSQL_ROOT_PASSWORD=rootpassword

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=1h
REFRESH_TOKEN_EXPIRATION=7d

# AI & LLM Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-6-20250805
ANTHROPIC_MAX_TOKENS=4096

# External APIs
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# Google OAuth
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_TIMEOUT=3600000

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@yourapp.com

# AWS Configuration (for deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
AWS_S3_BUCKET=job-app-uploads
AWS_RDS_ENDPOINT=job-app-db.xxxxx.rds.amazonaws.com
AWS_RDS_PORT=3306

# Redis Configuration (optional)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Monitoring & Logging
SENTRY_DSN=https://xxxxx@xxxx.ingest.sentry.io/xxxxx
DATADOG_API_KEY=xxxxxxxxxxxxx

# Feature Flags
FEATURE_AUTO_APPLY=false
FEATURE_EMAIL_ALERTS=false
FEATURE_ADVANCED_ANALYTICS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
HELMET_ENABLED=true
RATE_LIMITER_ENABLED=true
CSRF_PROTECTION_ENABLED=true

# Frontend Configuration
REACT_APP_API_URL=http://localhost/api
REACT_APP_GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
REACT_APP_ENVIRONMENT=development
REACT_APP_VERSION=1.0.0

# Deployment Configuration
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_INSTANCE_TYPE=t3.medium
DEPLOYMENT_AUTO_SCALING_MIN=2
DEPLOYMENT_AUTO_SCALING_MAX=10
