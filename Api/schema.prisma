generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  email              String               @id @unique
  password           String?
  googleId           String?              @unique
  profilePic         String?
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  refreshToken       String?              @db.LongText
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  applications       Application[]
  performanceMetrics PerformanceMetrics[]
  resumes            Resume[]
  generatedContent   GeneratedContent[]
  agentLogs          AgentLog[]
  followUps          FollowUp[]
  preferences        UserPreferences?
  jobAlerts          JobAlert[]
}

model Application {
  userId        String
  jobListingId  String
  status        String
  dateApplied   DateTime
  dateUpdated   DateTime?
  notes         String?
  jobName       String
  jobLink       String?      @db.LongText
  companyName   String?

  platformName  String?
  platform      platformName? @relation(fields: [platformName], references: [platformName], onDelete: SetNull)

  user          User   @relation(fields: [userId], references: [email], onDelete: Cascade)

  @@id([userId, jobListingId])
  @@index([status])
}

model PerformanceMetrics {
  userId          String
  platformName    String
  totalJobsViewed Int
  jobsApplied     Int
  rejections      Int
  interviews      Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User         @relation(fields: [userId], references: [email], onDelete: Cascade)
  platform        platformName @relation(fields: [platformName], references: [platformName], onDelete: Cascade)

  @@id([userId, platformName])
}

model platformName {
  platformName        String               @id @unique
  createdDate         DateTime

  performanceMetrics  PerformanceMetrics[]
  applications        Application[]
}

model Resume {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [email], onDelete: Cascade)
  content    String   @db.LongText
  fileName   String
  skills     Json?
  experience Json?
  education  Json?
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model GeneratedContent {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [email], onDelete: Cascade)
  contentType String   // "cover_letter" | "cold_email"
  jobId       String?  // Links to JSearch job_id
  jobTitle    String?
  companyName String?
  content     String   @db.LongText
  metadata    Json?    // Stores tone, regeneration count, etc.
  createdAt   DateTime @default(now())
}

model AgentLog {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [email], onDelete: Cascade)
  agentType String   // "cover_letter" | "cold_email" | "follow_up" | "analytics"
  action    String
  input     Json?
  output    Json?
  status    String   // "success" | "failed"
  error     String?  @db.Text
  createdAt DateTime @default(now())
}

model FollowUp {
  id              Int      @id @default(autoincrement())
  userId          String
  user            User     @relation(fields: [userId], references: [email], onDelete: Cascade)
  applicationId   Int
  jobListingId    String
  jobTitle        String
  companyName     String

  emailSubject    String   @db.VarChar(500)
  emailBody       String   @db.LongText
  followUpCount   Int      @default(1) // 1st, 2nd, or 3rd follow-up

  status          String   @default("pending") // "pending" | "approved" | "sent"
  dismissed       Boolean  @default(false)
  sentAt          DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model UserPreferences {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [email], onDelete: Cascade)

  // Search criteria
  preferredRoles   Json     // ["Software Engineer", "Full Stack Developer"]
  preferredLocations Json   // ["Remote", "San Francisco, CA"]
  salaryMin        Int?
  salaryMax        Int?
  remoteOnly       Boolean  @default(false)

  // Platform and alert settings
  platforms        Json     // ["LinkedIn", "Indeed", "Glassdoor"]
  alertFrequency   String   @default("manual") // "manual" | "daily" | "weekly"
  matchThreshold   Int      @default(60) // 0-100
  maxAlertsPerCheck Int     @default(10)
  autoApplyEnabled Boolean  @default(false)

  // Timestamps
  lastInitialized  DateTime @default(now())
  lastModified     DateTime @updatedAt

  @@index([userId])
}

model JobAlert {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [email], onDelete: Cascade)

  // Job details
  jobId       String   // JSearch job_id for deduplication
  jobTitle    String
  companyName String
  matchScore  Int      // 0-100 from matching.service.js
  jobLink     String   @db.LongText
  location    String?
  salary      String?
  platform    String

  // Alert state
  seen        Boolean  @default(false)
  dismissed   Boolean  @default(false)
  applied     Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, seen])
  @@index([jobId])
  @@unique([userId, jobId]) // Prevent duplicate alerts
}
